# === Application Settings ===
PROJECT_NAME=SpeechCoach API
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG

# === Database Configuration ===
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_DB=speechcoach

# === Frontend URL (for email verification links) ===
FRONTEND_URL=http://localhost:3000

# === Email Configuration (Mailtrap example) ===
MAIL_USERNAME=your_mailtrap_user
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM=noreply@speechcoach.com
MAIL_FROM_NAME=SpeechCoach
MAIL_PORT=587
MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# === Celery/Redis Configuration ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === AI/ML Configuration ===
# Backend for coaching: "ollama" (local) or "groq" (cloud)
SPEECHCOACH_COACHING_BACKEND=ollama
SPEECHCOACH_LLM_MODEL=speechcoach

# === Groq API Configuration (if using Groq backend) ===
GROQ_API_KEY=your_groq_api_key_here
